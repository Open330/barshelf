{
  "$schema": "https://barshelf.jiun.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.hello",
  "name": "Hello",
  "version": "0.1.0",
  "icon": "hand.wave",
  "bucket": { "group": "Demo", "order": 10, "size": "S" },

  "entry": { "kind": "exec" },
  "source": {
    "kind": "exec",
    "command": ["./hello.sh"],
    "timeoutMs": 5000,
    "output": "viewtree"
  },

  "refresh": { "onOpen": true, "interval": 60, "staleAfterSec": 30 },
  "permissions": { "exec": [{ "command": "./hello.sh", "allowedArgs": [[]] }] }
}
