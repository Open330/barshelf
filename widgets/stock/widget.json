{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.stock",
  "name": "Stock",
  "version": "0.1.0",
  "icon": "chart.line.uptrend.xyaxis",
  "bucket": { "group": "Demo", "order": 15, "size": "S" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": { "onOpen": true, "interval": 300, "staleAfterSec": 300 },

  "permissions": {
    "network": ["query1.finance.yahoo.com"]
  },

  "settings": [
    { "key": "symbol", "title": "Ticker", "type": "string", "default": "AAPL" }
  ],

  "appearance": {
    "accent": "green"
  }
}
