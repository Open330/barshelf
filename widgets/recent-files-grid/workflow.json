{
  "schemaVersion": 1,
  "kind": "workflow",
  "_comment": "Stashbar-style recent files with a Grid/List view toggle (a `switch` on settings.viewMode) and an adjustable thumbnail size. Tiles/rows drag out to Finder and open on click.",

  "sources": {
    "files": {
      "use": "fs.directory",
      "with": {
        "path": "${settings.folder}",
        "watch": true,
        "skipHidden": true,
        "sortBy": "modifiedAt",
        "sortDirection": "descending",
        "limit": "${settings.limit}"
      }
    }
  },

  "view": {
    "type": "vstack",
    "spacing": 0,
    "children": [
      {
        "type": "hstack",
        "spacing": 8,
        "padding": 10,
        "children": [
          { "type": "image", "source": { "kind": "sfSymbol", "name": "square.grid.2x2" }, "size": 15, "tint": "secondary" },
          { "type": "text", "text": "${file.basename(settings.folder)}", "role": "title", "lineLimit": 1 },
          { "type": "spacer" },
          { "type": "text", "text": "${count(sources.files.items)} files", "role": "caption", "foreground": "secondary" }
        ]
      },
      { "type": "divider" },
      {
        "switch": "${settings.viewMode}",
        "cases": {
          "List": {
            "type": "list",
            "spacing": 2,
            "padding": 6,
            "items": {
              "forEach": "$.sources.files.items",
              "as": "file",
              "template": {
                "type": "hstack",
                "id": "row-${file.path}",
                "spacing": 8,
                "padding": 6,
                "drag": { "filePath": "${file.path}" },
                "action": { "type": "openFile", "path": "${file.path}" },
                "children": [
                  { "type": "image", "source": { "kind": "fileThumbnail", "path": "${file.path}", "modifiedAt": "${file.modifiedAt}" }, "size": "${settings.thumbSize}" },
                  {
                    "type": "vstack",
                    "spacing": 2,
                    "widthFill": true,
                    "children": [
                      { "type": "text", "text": "${file.name}", "role": "body", "lineLimit": 1 },
                      { "type": "text", "text": "${date.relative(file.modifiedAt)}", "role": "caption", "foreground": "tertiary" }
                    ]
                  }
                ]
              }
            }
          }
        },
        "default": {
          "type": "grid",
          "spacing": 10,
          "padding": 10,
          "size": "${add(settings.thumbSize, 22)}",
          "items": {
            "forEach": "$.sources.files.items",
            "as": "file",
            "template": {
              "type": "vstack",
              "spacing": 4,
              "id": "tile-${file.path}",
              "drag": { "filePath": "${file.path}" },
              "action": { "type": "openFile", "path": "${file.path}" },
              "children": [
                { "type": "image", "source": { "kind": "fileThumbnail", "path": "${file.path}", "modifiedAt": "${file.modifiedAt}" }, "size": "${settings.thumbSize}" },
                { "type": "text", "text": "${file.name}", "role": "caption", "lineLimit": 1 }
              ]
            }
          }
        }
      }
    ]
  },

  "empty": {
    "type": "empty",
    "icon": "square.grid.2x2",
    "title": "No files",
    "subtitle": "Files added to this folder appear here."
  },

  "status": {
    "tooltip": "${count(sources.files.items)} files in ${file.basename(settings.folder)}"
  }
}
