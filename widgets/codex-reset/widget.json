{
  "$schema": "https://barshelf.jiun.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.codex-reset",
  "name": "Codex Reset",
  "version": "0.1.0",
  "icon": "cloud.sun.fill",
  "bucket": { "group": "Developer", "order": 41, "size": "S" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": {
    "onOpen": true,
    "interval": 1800,
    "staleAfterSec": 1800,
    "triggers": ["wake"]
  },

  "permissions": {
    "network": ["www.willcodexquotareset.com"]
  },

  "appearance": {
    "accent": "orange"
  }
}
