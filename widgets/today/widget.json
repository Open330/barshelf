{
  "$schema": "https://barshelf.jiun.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.today",
  "name": "Today",
  "version": "0.1.0",
  "icon": "calendar",
  "bucket": { "group": "Demo", "order": 10, "size": "M" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": { "onOpen": true, "interval": 60, "staleAfterSec": 60 },

  "permissions": {
    "exec": [
      {
        "command": "/bin/date",
        "allowedArgs": [["+{\"weekday\":\"%A\",\"month\":\"%b\",\"day\":\"%d\",\"time\":\"%H:%M\",\"year\":\"%Y\"}"]],
        "maxOutputBytes": 4096,
        "sensitiveOutput": false
      }
    ]
  },

  "appearance": {
    "accent": "red"
  }
}
