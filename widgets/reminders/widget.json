{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.reminders",
  "name": "Reminders",
  "version": "0.1.0",
  "icon": "checklist",
  "bucket": { "group": "Media", "order": 11, "size": "S" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": { "onOpen": true, "interval": 60, "staleAfterSec": 60 },

  "permissions": {
    "exec": [
      {
        "command": "/bin/sh",
        "allowedArgs": [["-c", "n=$(/usr/bin/osascript -e 'tell application \"Reminders\" to count (reminders whose completed is false)' 2>/dev/null); [ -z \"$n\" ] && n=0; echo '{\"count\":'\"$n\"'}'"]],
        "maxOutputBytes": 4096,
        "sensitiveOutput": false
      }
    ]
  },

  "appearance": {
    "accent": "orange"
  }
}
