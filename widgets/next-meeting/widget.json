{
  "$schema": "https://barshelf.jiun.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.next-meeting",
  "name": "Next Meeting",
  "version": "0.1.0",
  "icon": "calendar.badge.clock",
  "bucket": { "group": "Productivity", "order": 10, "size": "M" },

  "entry": { "kind": "script", "runtime": "deno-ts@1" },
  "source": { "kind": "script", "output": "viewtree" },

  "refresh": {
    "onOpen": true,
    "interval": 60,
    "staleAfterSec": 60,
    "triggers": ["wake", "popup-open"]
  },

  "permissions": {
    "exec": [
      {
        "command": "/usr/bin/osascript",
        "allowedArgs": [["-l", "JavaScript", "./calendar.js", "*", "*"]],
        "maxOutputBytes": 65536,
        "sensitiveOutput": true
      }
    ]
  },

  "settings": [
    {
      "key": "lookAheadDays",
      "title": "Look ahead (days)",
      "type": "integer",
      "default": 7,
      "min": 1,
      "max": 30
    },
    {
      "key": "includeAllDay",
      "title": "Include all-day events",
      "type": "boolean",
      "default": false
    }
  ],

  "appearance": {
    "accent": "blue",
    "cardStyle": "tinted"
  }
}
