{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.downloads-watch",
  "name": "Downloads Watch",
  "version": "0.1.0",
  "icon": "arrow.down.circle.fill",
  "bucket": { "group": "Files", "order": 40, "size": "M" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": {
    "onOpen": true,
    "interval": null,
    "staleAfterSec": 300,
    "triggers": [{ "fs": "~/Downloads" }]
  },

  "permissions": {
    "readPaths": ["~/Downloads"]
  },

  "appearance": {
    "accent": "orange"
  }
}
