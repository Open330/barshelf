{
  "$schema": "https://barshelf.jiun.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.local-time",
  "name": "Local Time",
  "version": "0.1.0",
  "icon": "clock.fill",
  "bucket": { "group": "Demo", "order": 40, "size": "S" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": { "onOpen": true, "interval": 60, "staleAfterSec": 60 },

  "permissions": {
    "exec": [
      {
        "command": "/bin/date",
        "allowedArgs": [["+%H:%M:%S"], ["+%A, %b %d"]],
        "maxOutputBytes": 4096,
        "sensitiveOutput": false
      }
    ]
  },

  "appearance": {
    "accent": "blue"
  }
}
