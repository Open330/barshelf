{
  "$schema": "https://barshelf.jiun.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.top-processes",
  "name": "Top Processes",
  "version": "0.1.0",
  "icon": "cpu.fill",
  "bucket": { "group": "System", "order": 20, "size": "M" },

  "entry": { "kind": "script", "runtime": "deno-ts@1" },
  "source": { "kind": "script", "output": "viewtree" },

  "refresh": { "onOpen": true, "interval": 120, "staleAfterSec": 120 },

  "permissions": {
    "exec": [
      {
        "command": "/bin/ps",
        "allowedArgs": [["-axo", "comm,%cpu", "-r"]],
        "maxOutputBytes": 65536,
        "sensitiveOutput": false
      }
    ]
  },

  "appearance": {
    "accent": "purple",
    "density": "compact"
  }
}
