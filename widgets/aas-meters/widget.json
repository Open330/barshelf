{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.aas-meters",
  "name": "aas Usage",
  "version": "0.1.0",
  "icon": "gauge",
  "bucket": { "group": "Agents", "order": 21, "size": "M" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": { "onOpen": true, "interval": null, "staleAfterSec": 600 },

  "permissions": {
    "exec": [
      {
        "command": "aas",
        "allowedArgs": [["usage", "--json"]],
        "maxOutputBytes": 1048576,
        "sensitiveOutput": false
      }
    ],
    "env": ["AAS_BIN"]
  },

  "appearance": {
    "accent": "orange"
  }
}
