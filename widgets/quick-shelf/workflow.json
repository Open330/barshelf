{
  "schemaVersion": 1,
  "kind": "workflow",
  "_comment": "Permission-free launcher. Host openApp/openFile/openURL actions only run after an explicit click.",

  "sources": {},

  "view": {
    "type": "vstack",
    "spacing": 8,
    "children": [
      {
        "type": "hstack",
        "spacing": 6,
        "children": [
          { "type": "image", "source": { "kind": "sfSymbol", "name": "square.grid.2x2.fill" }, "size": 16, "tint": "accent" },
          { "type": "text", "text": "Quick Shelf", "role": "title", "lineLimit": 1 },
          { "type": "spacer" },
          { "type": "badge", "text": "6 shortcuts", "tone": "accent" }
        ]
      },
      {
        "type": "list",
        "spacing": 4,
        "searchPlaceholder": "Find a shortcut",
        "items": [
          {
            "type": "hstack",
            "id": "quick-finder",
            "spacing": 8,
            "padding": 7,
            "action": { "type": "openApp", "value": "com.apple.finder" },
            "children": [
              { "type": "image", "source": { "kind": "sfSymbol", "name": "face.smiling" }, "size": 18, "tint": "accent" },
              { "type": "text", "text": "Finder", "role": "body" },
              { "type": "spacer" },
              { "type": "text", "text": "App", "role": "caption", "foreground": "tertiary" }
            ]
          },
          {
            "type": "hstack",
            "id": "quick-calendar",
            "spacing": 8,
            "padding": 7,
            "action": { "type": "openApp", "value": "com.apple.iCal" },
            "children": [
              { "type": "image", "source": { "kind": "sfSymbol", "name": "calendar" }, "size": 18, "tint": "accent" },
              { "type": "text", "text": "Calendar", "role": "body" },
              { "type": "spacer" },
              { "type": "text", "text": "App", "role": "caption", "foreground": "tertiary" }
            ]
          },
          {
            "type": "hstack",
            "id": "quick-custom-app",
            "spacing": 8,
            "padding": 7,
            "action": { "type": "openApp", "value": "${settings.appIdentifier}" },
            "children": [
              { "type": "image", "source": { "kind": "sfSymbol", "name": "app.fill" }, "size": 18, "tint": "accent" },
              { "type": "text", "text": "${settings.appName}", "role": "body", "lineLimit": 1 },
              { "type": "spacer" },
              { "type": "text", "text": "Favorite app", "role": "caption", "foreground": "tertiary" }
            ]
          },
          {
            "type": "hstack",
            "id": "quick-custom-folder",
            "spacing": 8,
            "padding": 7,
            "action": { "type": "openFile", "path": "${settings.folderPath}" },
            "children": [
              { "type": "image", "source": { "kind": "sfSymbol", "name": "folder.fill" }, "size": 18, "tint": "accent" },
              { "type": "text", "text": "${settings.folderName}", "role": "body", "lineLimit": 1 },
              { "type": "spacer" },
              { "type": "text", "text": "Folder", "role": "caption", "foreground": "tertiary" }
            ]
          },
          {
            "type": "hstack",
            "id": "quick-applications",
            "spacing": 8,
            "padding": 7,
            "action": { "type": "openFile", "path": "/Applications" },
            "children": [
              { "type": "image", "source": { "kind": "sfSymbol", "name": "square.grid.3x3.fill" }, "size": 18, "tint": "accent" },
              { "type": "text", "text": "Applications", "role": "body" },
              { "type": "spacer" },
              { "type": "text", "text": "Folder", "role": "caption", "foreground": "tertiary" }
            ]
          },
          {
            "type": "hstack",
            "id": "quick-custom-site",
            "spacing": 8,
            "padding": 7,
            "action": { "type": "openURL", "url": "${settings.siteURL}" },
            "children": [
              { "type": "image", "source": { "kind": "sfSymbol", "name": "globe" }, "size": 18, "tint": "accent" },
              { "type": "text", "text": "${settings.siteName}", "role": "body", "lineLimit": 1 },
              { "type": "spacer" },
              { "type": "text", "text": "Website", "role": "caption", "foreground": "tertiary" }
            ]
          }
        ]
      }
    ]
  },

  "status": {
    "tooltip": "Open apps, folders, and websites"
  }
}
