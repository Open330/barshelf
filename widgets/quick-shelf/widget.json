{
  "$schema": "https://barshelf.dev/schema/widget-0.1.json",
  "schemaVersion": 1,
  "id": "dev.barshelf.quick-shelf",
  "name": "Quick Shelf",
  "version": "0.1.0",
  "icon": "square.grid.2x2.fill",
  "bucket": { "group": "Productivity", "order": 20, "size": "M" },

  "entry": { "kind": "workflow", "main": "workflow.json" },

  "refresh": { "onOpen": true, "interval": null, "staleAfterSec": 86400 },

  "settings": [
    { "key": "appName", "title": "Favorite app label", "type": "string", "default": "Notes" },
    { "key": "appIdentifier", "title": "Favorite app bundle ID or name", "type": "string", "default": "com.apple.Notes" },
    { "key": "folderName", "title": "Favorite folder label", "type": "string", "default": "Downloads" },
    { "key": "folderPath", "title": "Favorite folder path", "type": "directory", "default": "~/Downloads" },
    { "key": "siteName", "title": "Favorite website label", "type": "string", "default": "GitHub" },
    { "key": "siteURL", "title": "Favorite website URL", "type": "string", "default": "https://github.com" }
  ],

  "appearance": {
    "accent": "purple",
    "density": "compact"
  }
}
